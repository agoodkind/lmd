{
  "title": "lmd observability",
  "uid": "lmd-observability",
  "schemaVersion": 39,
  "tags": ["lmd", "mlx"],
  "timezone": "browser",
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "title": "Completed request rate (per kind)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (model_kind) (rate(lmd_backend_trace_events_total{phase=\"request_completed\"}[1m]))",
          "legendFormat": "{{model_kind}}"
        }
      ]
    },
    {
      "title": "Time by phase (avg)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (phase) (rate(lmd_backend_phase_duration_seconds_sum[5m])) / sum by (phase) (rate(lmd_backend_phase_duration_seconds_count[5m]))",
          "legendFormat": "{{phase}} avg"
        }
      ]
    },
    {
      "title": "Time by phase (share of total)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (phase) (rate(lmd_backend_phase_duration_seconds_sum[5m]))",
          "legendFormat": "{{phase}}"
        }
      ]
    },
    {
      "title": "Request duration (avg / max)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (span) (rate(lmd_backend_request_duration_seconds_sum[5m])) / sum by (span) (rate(lmd_backend_request_duration_seconds_count[5m]))",
          "legendFormat": "{{span}} avg"
        },
        {
          "expr": "max by (span) (lmd_backend_request_duration_seconds_max)",
          "legendFormat": "{{span}} max"
        }
      ]
    },
    {
      "title": "Models loaded",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "lmd_broker_loaded_models", "legendFormat": "models loaded" }
      ]
    }
  ]
}

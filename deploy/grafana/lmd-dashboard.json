{
  "title": "lmd observability",
  "uid": "lmd-observability",
  "schemaVersion": 39,
  "tags": ["lmd", "mlx"],
  "timezone": "browser",
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "title": "Request rate (per kind)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (kind, result) (rate(lmd_requests_total[1m]))",
          "legendFormat": "{{kind}} {{result}}"
        }
      ]
    },
    {
      "title": "Time by phase (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, phase) (rate(lmd_phase_duration_seconds_bucket[5m])))",
          "legendFormat": "{{phase}} p95"
        }
      ]
    },
    {
      "title": "Time by phase (share of total)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (phase) (rate(lmd_phase_duration_seconds_sum[5m]))",
          "legendFormat": "{{phase}}"
        }
      ]
    },
    {
      "title": "Request duration p50/p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, kind) (rate(lmd_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{kind}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, kind) (rate(lmd_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{kind}} p95"
        }
      ]
    },
    {
      "title": "GPU memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "lmd_gpu_active_bytes", "legendFormat": "active" },
        { "expr": "lmd_gpu_cache_bytes", "legendFormat": "cache" },
        { "expr": "lmd_gpu_peak_bytes", "legendFormat": "peak" }
      ]
    },
    {
      "title": "In-flight requests + models loaded",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "lmd_inflight_requests", "legendFormat": "inflight {{kind}}" },
        { "expr": "lmd_models_loaded", "legendFormat": "models loaded" }
      ]
    },
    {
      "title": "GPU power (W)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "watt" } },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "lmd_power_watts", "legendFormat": "system power" }]
    }
  ]
}

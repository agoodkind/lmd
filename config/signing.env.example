#
#  signing.env.example
#  lmd
#
#  Copy to config/signing.env and fill in your values. The real file
#  is gitignored. Sourced by scripts/sign-binaries.sh and
#  scripts/notarize.sh; never read by lmd binaries themselves.
#
#  Find CODE_SIGN_IDENTITY with:
#      security find-identity -v -p codesigning
#  Pick the "Developer ID Application: <Your Name> (TEAMID)" line and
#  prefer the 40-char SHA1 hash over the human-readable name; if you
#  have multiple Developer ID Application certs (renewed, etc.), the
#  name is ambiguous and codesign will refuse with "ambiguous".
#
#  Find TEAM_ID at:
#      https://developer.apple.com/account
#
#  Create the notary keychain profile once with:
#      make notary-setup
#  That wraps `xcrun notarytool store-credentials` and stores the
#  app-specific password in the keychain under NOTARY_PROFILE.
#

CODE_SIGN_IDENTITY="0000000000000000000000000000000000000000"
DEVELOPMENT_TEAM="TEAMID0000"
NOTARY_PROFILE="lmd-notary"
BUNDLE_ID_PREFIX="io.goodkind.lmd"
